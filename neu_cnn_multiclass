lity for each correct prediction\n","        correct_confidences = y_test_pred_probs[correct_indices].max(axis=1)\n","\n","        # Sort by confidence\n","        sorted_correct_idx = correct_indices[np.argsort(correct_confidences)]\n","\n","        low_conf_samples = sorted_correct_idx[:3]  # 3 lowest confidence\n","        high_conf_samples = sorted_correct_idx[-3:]  # 3 highest confidence\n","\n","        confidence_samples = np.concatenate([low_conf_samples, high_conf_samples])\n","\n","        if len(confidence_samples) >= 4:\n","            X_conf_samples = X_test[confidence_samples]\n","            cam_conf = scorecam(score_function, X_conf_samples, penultimate_layer='last_conv')\n","\n","            fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n","            axes = axes.ravel()\n","\n","            for i, idx in enumerate(confidence_samples):\n","                ax = axes[i]\n","\n","                # Original image\n","                img = X_test[idx]\n","\n","                # Overlay CAM\n","                heatmap = cam_conf[i]\n","                heatmap = np.uint8(255 * heatmap)\n","                heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET)\n","                heatmap = cv2.cvtColor(heatmap, cv2.COLOR_BGR2RGB)\n","                heatmap = cv2.resize(heatmap, (SIZE, SIZE))\n","\n","                # Superimpose\n","                superimposed = cv2.addWeighted(\n","                    (img * 255).astype(np.uint8), 0.6,\n","                    heatmap, 0.4, 0\n","                )\n","\n","                ax.imshow(superimposed)\n","                ax.axis('off')\n","\n","                true_label = class_names[y_test[idx]]\n","                pred_class = y_test_pred[idx]\n","                confidence = y_test_pred_probs[idx, pred_class]\n","\n","                conf_level = \"LOW\" if i < 3 else \"HIGH\"\n","\n","                ax.set_title(\n","                    f\"✓ {true_label} ({conf_level} CONF)\\n\"\n","                 