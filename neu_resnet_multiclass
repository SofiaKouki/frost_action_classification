)\n","\n","    except Exception as e:\n","        print(f\"Error in comprehensive grid: {e}\")\n","\n","# ============================================================================\n","# SUMMARY STATISTICS\n","# ============================================================================\n","print(\"\\n\" + \"=\"*80)\n","print(\"SUMMARY STATISTICS\")\n","print(\"=\"*80)\n","\n","if score_cam is not None:\n","    try:\n","        print(f\"\\nTotal test samples: {len(X_test)}\")\n","        print(f\"Correct predictions: {np.sum(y_test == y_test_pred)}\")\n","        print(f\"Incorrect predictions: {np.sum(y_test != y_test_pred)}\")\n","\n","        print(\"\\nPer-class statistics:\")\n","        for class_idx in range(num_classes):\n","            class_mask = y_test == class_idx\n","            correct = np.sum((y_test == class_idx) & (y_test_pred == class_idx))\n","            total = np.sum(class_mask)\n","            print(f\"  {label_to_class[class_idx]}: {correct}/{total} correct ({100*correct/total:.1f}%)\")\n","\n","        print(\"\\nConfusion patterns:\")\n","        for true_class in range(num_classes):\n","            for pred_class in range(num_classes):\n","                if true_class != pred_class:\n","                    confused = np.sum((y_test == true_class) & (y_test_pred == pred_class))\n","                    if confused > 0:\n","                        print(f\"  {label_to_class[true_class]} → {label_to_class[pred_class]}: {confused} cases\")\n","\n","        max_probs = np.max(y_test_pred_probs, axis=1)\n","        uncertain = np.sum(max_probs < 0.8)\n","        high_conf = np.sum(max_probs > 0.9)\n","\n","        print(f\"\\nConfidence distribution:\")\n","        print(f\"  High confidence (>0.9): {high_conf}\")\n","        print(f\"  Uncertain (<0.8): {uncertain}\")\n","\n","        print(f\"\\nAll Score-CAM visualizations saved to: {save_dir}\")\n","\n","    except Exception as e:\n","        print(f\"Error generating summary: {e}\")\n"