 for class_idx in range(num_classes):\n","            # Get correct predictions for this class\n","            correct_class = np.where((y_test == class_idx) & (y_test_pred == class_idx))[0]\n","\n","            if len(correct_class) >= 4:\n","                # Select 4 diverse samples (high conf, medium conf, etc)\n","                probs = y_test_pred_probs[correct_class, class_idx]\n","                sorted_idx = np.argsort(probs)[::-1]\n","\n","                # Pick from different confidence levels\n","                selected = [\n","                    correct_class[sorted_idx[0]],  # Highest confidence\n","                    correct_class[sorted_idx[len(sorted_idx)//3]],\n","                    correct_class[sorted_idx[2*len(sorted_idx)//3]],\n","                    correct_class[sorted_idx[-1]]  # Lowest confidence\n","                ]\n","            else:\n","                selected = correct_class[:4]\n","\n","            for col_idx, idx in enumerate(selected):\n","                img = X_test[idx]\n","\n","                try:\n","                    cam, cam_confidence, target_class = score_cam.generate_cam(img, target_class=class_idx)\n","                    cam_resized = cv2.resize(cam, (SIZE, SIZE))\n","                    overlay = overlay_heatmap_scorecam(img, cam_resized, alpha=0.4)\n","                except:\n","                    overlay = img\n","\n","                ax = axes[class_idx, col_idx] if num_classes > 1 else axes[col_idx]\n","                ax.imshow(overlay)\n","                ax.axis('off')\n","\n","                pred_prob = y_test_pred_probs[idx, class_idx]\n","                ax.set_title(f\"Prob: {pred_prob:.3f}\", fontsize=9)\n","\n","            # Hide unused subplots for this class\n","            for col_idx in range(len(selected), 4):\n","                ax = axes[class_idx, col_idx] if num_classes > 1 else axes[col_idx]\n","                ax.axis('off')\n","\n","            # Add class label\n","            